<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:padding="8dp">

    <!-- Khung chính (viền bo tròn màu hồng nhạt) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@drawable/background_cart_item"
        android:padding="2dp">

        <!-- Hình sản phẩm -->

        <!-- Nội dung bên phải -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/image_product_cart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:background="@drawable/background_image_round"
                android:scaleType="centerCrop"
                android:src="@drawable/food_sandwich" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="7.5"
            android:background="@drawable/background_left_rounded_white"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <!-- Hàng 1: Tên + nút xóa -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp">

                <TextView
                    android:id="@+id/text_name_cart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sandwich"
                    android:textColor="#000"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/button_remove_cart"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/icon_trash"/>
            </RelativeLayout>

            <!-- 🟣 Hàng 2: Giá bên trái - Số lượng bên phải -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <!-- Giá -->
                <TextView
                    android:id="@+id/text_price_cart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="50.000 VND/pc"
                    android:textColor="#EB4341"
                    android:textSize="14sp"
                    android:layout_gravity="top"
                    android:textStyle="bold"/>

                <!-- Ô số lượng -->
                <LinearLayout
                    android:id="@+id/quantity_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:gravity="end">

                    <Button
                        android:id="@+id/button_minus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="-"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#A71317"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:gravity="center"
                        android:stateListAnimator="@null"/>

                    <EditText
                        android:id="@+id/quantity_input"
                        android:layout_width="30dp"
                        android:layout_height="match_parent"
                        android:text="1"
                        android:inputType="number"
                        android:gravity="center"
                        android:background="@android:color/transparent"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                    <Button
                        android:id="@+id/button_plus"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:text="+"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#A71317"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp"
                        android:gravity="center"
                        android:stateListAnimator="@null"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã bán 18K+"
                    android:textSize="12sp"
                    android:textColor="#C0C0C0"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="   Lượt yêu thích 1K+"
                    android:textSize="12sp"
                    android:textColor="#C0C0C0"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
